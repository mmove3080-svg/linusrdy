# ── Client-side (exposed to browser, restrict by URL in Mapbox dashboard) ──
VITE_MAPBOX_TOKEN=pk.your_public_mapbox_token

# ── Server-side only (set these in Vercel → Project → Environment Variables) ──
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_SHIPMENTS_TABLE=Shipments
AIRTABLE_EVENTS_TABLE=Shipment Events
# Secret Mapbox token used by the serverless function for Directions API
MAPBOX_SERVER_TOKEN=sk.your_secret_mapbox_token
